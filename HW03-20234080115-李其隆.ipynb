   "source": [
    "import torch.nn.functional as F\n",
    "\n",
    "def label_smoothing_cross_entropy(logits, target, epsilon=0.1, reduction=\"mean\"):\n",
    "    if logits.ndim != 2:\n",
    "        raise ValueError(\"logits must have shape (batch_size, num_classes).\")\n",
    "    num_classes = logits.size(1)\n",
    "    if num_classes < 2:\n",
    "        raise ValueError(\"num_classes must be at least 2.\")\n",
    "\n",
    "    with torch.no_grad():\n",
    "        smooth_target = torch.full_like(logits, epsilon / (num_classes - 1))\n",
    "        smooth_target.scatter_(1, target.unsqueeze(1), 1.0 - epsilon)\n",
    "\n",
    "    log_probs = F.log_softmax(logits, dim=1)\n",
    "    loss = -(smooth_target * log_probs).sum(dim=1)\n",
    "\n",
    "    if reduction == \"mean\":\n",
    "        return loss.mean()\n",
    "    if reduction == \"sum\":\n",
    "        return loss.sum()\n",
    "    if reduction == \"none\":\n",
    "        return loss\n",
    "    raise ValueError(\"reduction must be 'mean', 'sum', or 'none'.\")\n",
    "\n",
    "logits = torch.tensor([[2.0, 0.5, -1.0, 0.0]])\n",
    "target = torch.tensor([0])\n",
    "loss = label_smoothing_cross_entropy(logits, target, epsilon=0.1)\n",
    "\n",
    "num_classes = logits.size(1)\n",
    "smoothed = torch.full_like(logits, 0.1 / (num_classes - 1))\n",
    "smoothed.scatter_(1, target.unsqueeze(1), 0.9)\n",
    "\n",
    "print(\"Smoothed target distribution:\", smoothed.numpy().round(6))\n",
    "print(f\"Label smoothing cross entropy: {loss.item():.6f}\")"
   ]
  }
